echo "secret.yaml" >> .gitignore
```

Your `.gitignore` will then look like:
```
node_modules/
__pycache__/
*.pyc
.env

# DB
*.db
*.db-shm
*.db-wal

# Virtual env
venv/
backend/venv/

# OS
.DS_Store

secret.yaml

# Gmail OAuth2 token (contains refresh_token — never commit)
backend/gmail_token.json
gmail_token.json
.gstack/
