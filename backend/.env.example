# App
APP_ENV=development
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/restaurant_agent
# For local dev with SQLite:
# DATABASE_URL=sqlite:///./restaurant_agent.db

# Anthropic / Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Groq (optional — if set, Groq is used INSTEAD of Claude)
GROQ_API_KEY=your-groq-api-key

# Telnyx (Voice + SMS)
TELNYX_API_KEY=your-telnyx-api-key
TELNYX_PUBLIC_KEY=your-telnyx-public-key
TELNYX_CONNECTION_ID=your-telnyx-connection-id
TELNYX_MESSAGING_PROFILE_ID=your-telnyx-messaging-profile-id

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=your-deepgram-api-key

# Stripe (Payments)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_ID_ESSENTIAL=price_essential_id
STRIPE_PRICE_ID_PRO=price_pro_id
STRIPE_PRICE_ID_ENTERPRISE=price_enterprise_id

# App URL (for webhooks)
BASE_URL=https://your-app.railway.app

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email / SMTP — for OTP login verification
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your-gmail@gmail.com

# Sentry (optional)
SENTRY_DSN=your-sentry-dsn # Only set if you want to use Sentry for error tracking
